{
  "name": "dash-eats-impressora",
  "version": "1.0.59",
  "description": "Aplicativo Desktop para Impressão DashEats",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "publish": "electron-builder --win -p always",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "DashEats",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-updater": "^6.3.9",
    "jimp": "^1.6.0",
    "node-thermal-printer": "^4.6.0",
    "png-to-ico": "^3.0.1",
    "socket.io-client": "^4.8.3"
  },
  "build": {
    "appId": "com.dasheats.impressora",
    "productName": "Impressora DashEats",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "publisherName": "DashEats",
      "artifactName": "Dash-Eats-Impressora-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "packElevateHelper": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "zKoide",
        "repo": "ImpressoraDesktop"
      }
    ],
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "renderer.js",
      "assets/**/*",
      "package.json"
    ],
    "asar": true
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "24.13.3"
  }
}