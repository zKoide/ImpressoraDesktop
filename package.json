{
  "name": "dasheats-printer",
  "version": "1.0.60",
  "description": "Impressora DashEats",
  "main": "main.js",
  "author": "DashEats",
  "build": {
    "appId": "com.dasheats.printer",
    "productName": "Impressora DashEats",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "packElevateHelper": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "zKoide",
        "repo": "ImpressoraDesktop"
      }
    ],
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "renderer.js",
      "assets/**/*",
      "package.json"
    ],
    "asar": true
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-updater": "^6.3.9",
    "jimp": "^1.6.0",
    "node-thermal-printer": "^4.6.0",
    "png-to-ico": "^3.0.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "24.13.3"
  }
}